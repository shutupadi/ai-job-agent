# ────────────────────────────────────────────────────────────────────
# AI Job Agent — environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ────────────────────────────────────────────────────────────────────

# ── Core ────────────────────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=INFO
TZ=Asia/Kolkata

# ── Database ────────────────────────────────────────────────────────
POSTGRES_USER=jobagent
POSTGRES_PASSWORD=jobagent
POSTGRES_DB=jobagent
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://jobagent:jobagent@db:5432/jobagent

# ── LLM routing ─────────────────────────────────────────────────────
# Primary provider used for ranking / resume tailoring / cover letters.
# Options: aicredits (paid INR gateway) | gemini (free) | groq (free) | claude (paid).
# This deployment uses the paid AiCredits gateway with free Groq as fallback.
LLM_PROVIDER=aicredits
LLM_FALLBACK_PROVIDER=groq
LLM_MAX_TOKENS=2048

# ── Gemini (Google AI Studio) — FREE ────────────────────────────────
# Get a key at: https://aistudio.google.com/app/apikey
# (Sign in with Google, click Create API Key, paste it below.)
GEMINI_API_KEY=REPLACE_ME
GEMINI_MODEL=gemini-2.0-flash

# ── Groq — FREE ─────────────────────────────────────────────────────
# Get a key at: https://console.groq.com/keys
# Used automatically if Gemini hits a rate limit or is unreachable.
GROQ_API_KEY=REPLACE_ME
GROQ_MODEL=llama-3.3-70b-versatile

# ── Anthropic Claude (optional, paid, NATIVE api) ───────────────────
# Only needed if you set LLM_PROVIDER=claude.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# ── AiCredits.in — OpenAI-compatible gateway (PAID, INR) ────────────
# One key → many models via the OpenAI chat-completions API.
# IMPORTANT: use a NON-thinking model. "gemini-2.0-flash" maps to
# gemini-2.5-flash (thinking) and truncates JSON output; deepseek-r1 too.
# Verified-good cheap choices: anthropic/claude-3-haiku, gemini-2.0-flash-lite.
AICREDITS_API_KEY=REPLACE_ME
AICREDITS_BASE_URL=https://api.aicredits.in/v1
AICREDITS_MODEL=anthropic/claude-3-haiku

# ── Auth (multi-user) ───────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=REPLACE_ME_WITH_A_LONG_RANDOM_SECRET
JWT_EXPIRE_MINUTES=10080
# Comma-separated emails granted the admin dashboard (/admin) + global settings.
# Evaluated at request time, so adding an email here promotes that account with
# no DB migration. Leave blank for no admins.
ADMIN_EMAILS=
# Google OAuth (optional). Same client id goes in the frontend as
# NEXT_PUBLIC_GOOGLE_CLIENT_ID (set in Vercel). Blank = hide the Google button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public URL of the frontend. Used for OAuth redirects AND as the CORS allow-list
# origin (Vercel *.vercel.app previews are always allowed). Set to your real URL.
FRONTEND_URL=http://localhost:3000

# ── Rate limiting (per client IP, in-memory) ────────────────────────
# Blunts brute-force logins / signup spam / upload + run abuse. Leave enabled in
# production. Set false only for load tests.
RATE_LIMIT_ENABLED=true

# ── Candidate identity (used for autofill) ──────────────────────────
CANDIDATE_FULL_NAME=Aditya Example
CANDIDATE_EMAIL=aditya@example.com
CANDIDATE_PHONE=+91-9000000000
CANDIDATE_LINKEDIN=https://www.linkedin.com/in/your-handle
CANDIDATE_GITHUB=https://github.com/your-handle
CANDIDATE_PORTFOLIO=https://your.site
CANDIDATE_CURRENT_LOCATION=Noida, India
CANDIDATE_WORK_AUTH=India / open to sponsorship
CANDIDATE_NOTICE_PERIOD=Immediately (final-year student)
CANDIDATE_EXPECTED_CTC_LPA=22

# ── Search preferences ──────────────────────────────────────────────
KEYWORDS=SDE,Software Engineer,Backend,Machine Learning,AI Engineer,Quant Analyst,Data Scientist
EXPERIENCE_LEVEL=entry           # entry | junior | mid | senior
LOCATIONS=Noida,Gurgaon,Bangalore,Hyderabad,Pune,Remote,India
INCLUDE_REMOTE=true
INCLUDE_INTERNATIONAL=true
MIN_SALARY_LPA=18

# Location gate: when true, only keep jobs that are in India, OR remote (if
# INCLUDE_REMOTE), OR international roles that mention visa sponsorship (if
# INCLUDE_INTERNATIONAL). Everything else is dropped before ranking — saves
# LLM quota. Set false to ingest everything and rely on ranking alone.
GEO_FILTER_ENABLED=true

# Experience gate. FALSE = open to ALL levels (multi-user default): the per-user
# AI matcher scores each job against that user's level. TRUE = fresher-only
# deployment (drops senior/3+yr jobs globally before ranking).
EXPERIENCE_FILTER_ENABLED=false
MAX_EXPERIENCE_YEARS=2

# Auto-cleanup: delete jobs older than N days that nobody applied to / tailored.
JOB_RETENTION_DAYS=30

# ── Source toggles ──────────────────────────────────────────────────
# greenhouse / lever / ycombinator / workday / oracle / linkedin / naukri
#   -> ALL sources are discovery + RANK only (APPLY_MODE=approval below). Nothing
#      is auto-submitted; you review the shortlist, tailor on approval, apply by
#      hand, then "Mark as applied". For richer LinkedIn data also run the local
#      logged-in discovery runner — see the LinkedIn block lower down.
ENABLE_GREENHOUSE=true
ENABLE_LEVER=true
ENABLE_YCOMBINATOR=true
ENABLE_WORKDAY=true
ENABLE_ORACLE=true
ENABLE_LINKEDIN=true
ENABLE_INDEED=false
ENABLE_NAUKRI=true
ENABLE_WELLFOUND=false
# Adzuna jobs API — high-volume, keyword-searched, ToS-clean, covers top firms
# (Goldman, Bloomberg, big tech). Free key at https://developer.adzuna.com.
ENABLE_ADZUNA=false
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=in
ADZUNA_MAX=60

# Ashby public job-board API (ToS-friendly, no key). Comma-separated board names
# (the slug in jobs.ashbyhq.com/<board>), e.g. "openai,ramp,notion,linear".
ENABLE_ASHBY=false
ASHBY_BOARDS=

# SmartRecruiters public posting API (no key). Comma-separated company identifiers
# (jobs.smartrecruiters.com/<Company>), e.g. "Visa,Square,Bosch".
ENABLE_SMARTRECRUITERS=false
SMARTRECRUITERS_COMPANIES=
SMARTRECRUITERS_MAX_PER_COMPANY=40

# Boards/companies to crawl (comma-separated slugs)
GREENHOUSE_BOARDS=stripe,airbnb,doordash,robinhood,databricks,coinbase,affirm,instacart,pinterest,figma
LEVER_COMPANIES=palantir,netflix,brex,ramp,scaleai,attentive,clever
YC_QUERY=software engineer

# Workday career sites — comma-separated "host|tenant|site[|Display Name]".
# Find these by opening a company's Workday careers page and copying the URL:
#   https://<host>/<locale>/<site>/...   e.g. nvidia.wd5.myworkdayjobs.com / NVIDIAExternalCareerSite
# The examples below are best-effort defaults; verify/replace with companies you
# care about (shards like wd1/wd5/wd12 and the site name occasionally change).
WORKDAY_TENANTS=ms.wd5.myworkdayjobs.com|ms|External|Morgan Stanley,nvidia.wd5.myworkdayjobs.com|nvidia|NVIDIAExternalCareerSite|NVIDIA,salesforce.wd12.myworkdayjobs.com|salesforce|External_Career_Site|Salesforce,adobe.wd5.myworkdayjobs.com|adobe|external_experienced|Adobe

# Oracle Recruiting Cloud (Candidate Experience) sites — "host|siteNumber[|Display]".
# Many banks/enterprises use this. Find host + CX_#### in the careers URL:
#   https://<host>/hcmUI/CandidateExperience/en/sites/CX_1001/...
ORACLE_TENANTS=jpmc.fa.oraclecloud.com|CX_1001|JPMorgan Chase

# Best-effort source volume caps (keep low + polite to avoid IP blocks)
LINKEDIN_MAX=25
NAUKRI_MAX=25
WORKDAY_MAX_PER_TENANT=40
ORACLE_MAX_PER_TENANT=40

# ── Apply behaviour ─────────────────────────────────────────────────
# approval = pipeline RANKS only and presents a shortlist for manual review; it
#            never auto-tailors or auto-submits. Tailoring happens on demand when
#            you approve a job. (auto = legacy auto-apply for ATS sources.)
APPLY_MODE=approval              # approval | auto
MIN_RANK_TO_APPLY=70             # shortlist threshold: only show jobs scoring >= this
MAX_APPLICATIONS_PER_RUN=15
RATE_LIMIT_SECONDS=45
HEADLESS_BROWSER=true

# ── LinkedIn logged-in DISCOVERY (LOCAL runner, NOT the Docker pipeline) ─
# Used only by:  python -m app.automation.linkedin_discover
# You log in once in a real browser; the session persists under
# storage/linkedin_profile. It scrapes recommended + searched jobs INTO THE DB
# for ranking — it NEVER applies. NOTE: scraping LinkedIn is against its User
# Agreement; keep volume polite. The 12h pipeline also pulls public LinkedIn.
LINKEDIN_DISCOVER_MAX=40

# ── LLM budget (avoid hitting free-tier daily quotas) ───────────────
# How many jobs to rank per run. With Gemini ~200 RPD + Groq ~100K TPD
# free tiers, 25 per run × 2 runs/day = 50/day fits with headroom.
MAX_RANKS_PER_RUN=25
# Seconds between consecutive LLM calls (keeps us under Gemini 15 RPM).
LLM_CALL_DELAY_SECONDS=4
# Stop ranking after this many 429-like failures in a row.
RANK_CIRCUIT_BREAKER=5

# ── Scheduler (cron in TZ above) ────────────────────────────────────
# Broad scan = fetch all sources + rank. Watchlist scan = fast re-rank of
# prioritised-company jobs for near-real-time alerts (scheduler daemon only).
SCHEDULE_CRON_MORNING=0 9 * * *
SCHEDULE_CRON_EVENING=0 19 * * *
SCHEDULE_WATCHLIST_MINUTES=30
SCHEDULE_CRON_DIGEST=30 8 * * *

# ── Notifications ───────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SUMMARY_EMAIL_TO=

# ── Job alerts (per-user email; Resend or Brevo) ────────────────────
# Leave EMAIL_PROVIDER blank to disable alerts entirely (safe no-op).
#   resend → set RESEND_API_KEY (https://resend.com)
#   brevo  → set BREVO_API_KEY  (https://www.brevo.com)
# EMAIL_FROM must be a verified sender/domain, e.g.
#   "AI Job Agent <alerts@yourdomain.com>"
EMAIL_PROVIDER=
RESEND_API_KEY=
BREVO_API_KEY=
EMAIL_FROM=
ALERT_MIN_SCORE=80
ALERT_MIN_INTERVAL_MINUTES=30

# ── Frontend → Backend URL ──────────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8000
